#!/usr/bin/env bash

set -euo pipefail

LAUNCH_CWD="$(pwd)"
SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
APP_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

if ! command -v bun >/dev/null 2>&1; then
  echo "cortex requires Bun. Install it first: https://bun.sh" >&2
  exit 1
fi

if [[ ! -d "$APP_DIR/src" ]]; then
  echo "Unable to locate the Cortex CLI source directory at $APP_DIR/src" >&2
  exit 1
fi

if [[ ! -e "$APP_DIR/node_modules/@cortex/sdk" || ! -e "$APP_DIR/node_modules/@cortex/shared" ]]; then
  cat >&2 <<EOF
Missing local Cortex workspace dependencies.

Expected:
  $APP_DIR/node_modules/@cortex/sdk
  $APP_DIR/node_modules/@cortex/shared

Run \`bun install\` from this checkout before launching Cortex.
EOF
  exit 1
fi

cd "$APP_DIR"
exec env CORTEX_LAUNCH_CWD="$LAUNCH_CWD" bun run src/index.tsx "$@"
